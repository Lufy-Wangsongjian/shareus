<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.shareus.transcode-monitor</string>
    <key>ProgramArguments</key>
    <array>
      <string>/usr/bin/python3</string>
      <string>__HOME__/.shareus/monitor-transcode.py</string>
    </array>
    <key>WorkingDirectory</key>
    <string>__HOME__/.shareus</string>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>__HOME__/.shareus/transcode-monitor.log</string>
    <key>StandardErrorPath</key>
    <string>__HOME__/.shareus/transcode-monitor.log</string>
  </dict>
</plist>
